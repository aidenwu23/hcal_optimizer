<!--
constants.xml
Centralized constants for the minimal detector.
Include this file BEFORE any section that uses these names.
-->
<lccdd>
    <define>
        <!-- Tracker region (used by other subsystems, if any) -->
        <constant name="tracker_region_rmax" value="4.0*m"/>
        <constant name="tracker_region_zmax" value="4.0*m"/>

        <!-- World definitions -->
        <constant name="world_dx"   value="5*m"/>
        <constant name="world_dy"   value="5*m"/>
        <constant name="world_dz"   value="5*m"/>

        <!-- XY segmentation (keep your centered grid) -->
        <constant name="cell_xy"    value="10*mm"/>
        <constant name="seg_offset" value="0*mm"/>

        <!-- Detector envelope / footprint -->
        <constant name="det_nsides" value="4"/>
        <constant name="det_rmin"   value="0*mm"/>
        <constant name="det_rmax"   value="0.50*m"/>

        <!-- Per-layer config -->
        <constant name="n_layers"   value="7"/>
        <constant name="t_absorber" value="1.52*cm"/>   <!-- Steel -->
        <constant name="t_scin"     value="0.4*cm"/>    <!-- Polystyrene (sensitive) -->
        <constant name="t_tape"     value="0.08*cm"/>   <!-- Kapton -->
        <constant name="t_layer"    value="t_absorber + t_scin + t_tape"/>

        <!-- Total half-thickness comes from layer stack -->
        <constant name="det_t"      value="n_layers * t_layer"/>
        <constant name="det_zmin"   value="20*cm"/>
        <constant name="det_zmax"   value="det_zmin + det_t"/>
        <constant name="det_dx"     value="0.50*m"/>    <!-- half-size in X -->
        <constant name="det_dy"     value="0.30*m"/>    <!-- half-size in Y -->

        <!-- Envelope padding (compute after det_* so env_* are correct) -->
        <constant name="env_zpad"   value="0.25*m"/>
        <constant name="env_xpad"   value="5*cm"/>
        <constant name="env_ypad"   value="5*cm"/>

        <!-- Envelope half-sizes -->
        <constant name="env_dz"     value="det_zmax + env_zpad"/>
        <constant name="env_dx"     value="det_dx + env_xpad"/>
        <constant name="env_dy"     value="det_dy + env_ypad"/>
    </define>
</lccdd>